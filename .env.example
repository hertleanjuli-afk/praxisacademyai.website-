# === PraxisAcademy AI — Environment Variables ===
# Copy this file to .env.local and fill in the values

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.praxisacademyai.com

# --- HubSpot (Shared account, separate "PraxisAcademy" pipeline) ---
HUBSPOT_ACCESS_TOKEN=

# --- Brevo (SEPARATE Academy account — set up before launch) ---
BREVO_API_KEY=
BREVO_WEBHOOK_SECRET=

# --- Calendly (SEPARATE Academy account) ---
NEXT_PUBLIC_CALENDLY_URL=

# --- Sales Control (Future separate system) ---
SALES_CONTROL_URL=
INBOUND_WEBHOOK_SECRET=

# --- Sales Control Dashboard (Future) ---
NEXT_PUBLIC_APP_URL=
